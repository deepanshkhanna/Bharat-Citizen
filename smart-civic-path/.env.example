# Smart Bharat — Environment Variables
# Copy this file to .env.local and fill in your API keys

# AI Provider keys (Set GROQ_API_KEY, OPENROUTER_API_KEY, or OPENAI_API_KEY)
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional: Override the model name (e.g. google/gemini-2.5-flash:free or llama-3.3-70b-versatile)
AI_MODEL=

# Optional: Bhashini API for multilingual support
BHASHINI_API_KEY=
BHASHINI_USER_ID=

# Supabase Postgres database connection
DATABASE_URL=
